# ==========================================
# ORIS — Configuration
# ==========================================
# Copier ce fichier en .env et adapter les valeurs
# ATTENTION : Ne jamais versionner le fichier .env !

# ── JWT ──────────────────────────────────────────────
# Secret JWT (obligatoire en production — DOIT être défini)
# Générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changeme_use_a_strong_random_secret

# ── Serveur backend ───────────────────────────────────
# Port du serveur backend (par défaut: 3001)
PORT=3001

# Environnement : development | production
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────
# URL du frontend autorisée (obligatoire en production)
# Exemple: https://oris.example.com
# En développement: laisser vide (toutes origines acceptées)
CORS_ORIGIN=

# ── Port Exposé (Docker) ─────────────────────────────
# Port exposé de l'interface web frontend via Docker
ORIS_PORT=3456

# ── ArangoDB ─────────────────────────────────────────
ARANGO_URL=http://localhost:8529
ARANGO_DB=oris
ARANGO_USER=root
# Mot de passe ArangoDB root (utilisé par docker-compose ET le backend)
ARANGO_ROOT_PASSWORD=changeme_arango_password
