# ==========================================
# ORIS — Configuration
# ==========================================
# Copier ce fichier en .env et adapter les valeurs

# JWT secret (obligatoire en production)
# Générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changeme_use_a_strong_random_secret

# Port du serveur backend (par défaut: 3001)
PORT=3001

# Base de données — choisir UN des formats suivants :
# SQLite (par défaut si rien n'est spécifié)
# DATABASE_URL=sqlite:///app/data/database.sqlite

# PostgreSQL
# DATABASE_URL=postgres://user:password@localhost:5432/oris

# MySQL / MariaDB
# DATABASE_URL=mysql://user:password@localhost:3306/oris
